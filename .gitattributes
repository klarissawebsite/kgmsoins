# Normalize all text files to LF in the repo regardless of OS.
* text=auto eol=lf

# Explicitly LF for code and config.
*.js    text eol=lf
*.bat   text eol=lf
*.ini   text eol=lf
*.jsx   text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.mjs   text eol=lf
*.cjs   text eol=lf
*.json  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.toml  text eol=lf
*.txt   text eol=lf
*.md    text eol=lf
*.sql   text eol=lf
*.css   text eol=lf
*.scss  text eol=lf
*.html  text eol=lf
*.svg   text eol=lf
*.sh    text eol=lf
*.ps1   text eol=lf
*.env*  text eol=lf
.coveragerc      text eol=lf
.gitattributes   text eol=lf
.gitignore       text eol=lf
.python-version  text eol=lf
.railwayignore   text eol=lf
